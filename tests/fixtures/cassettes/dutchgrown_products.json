22:09:20+02:00","product_id":15021592510840,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0557\/2873\/4375\/files\/Ranunculus_Brushmark_Seti-1.jpg?v=1776456560","width":990,"height":1320},{"id":75715458367864,"created_at":"2026-04-17T22:09:17+02:00","position":3,"updated_at":"2026-04-17T22:09:20+02:00","product_id":15021592510840,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0557\/2873\/4375\/files\/Ranunculus_Brushmark_Seti-3.jpg?v=1776456560","width":990,"height":1320},{"id":75715458400632,"created_at":"2026-04-17T22:09:17+02:00","position":4,"updated_at":"2026-04-17T22:09:20+02:00","product_id":15021592510840,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0557\/2873\/4375\/files\/Ranunculus_Brushmark_Seti-4.jpg?v=1776456560","width":990,"height":1320}],"options":[{"name":"Order size","position":1,"values":["3","6","12","15"]}]},{"id":15021592478072,"title":"Ranunculus Brushmark Cesar®","handle":"ranunculus-bruskmark-cesar","body_html":"\u003cp\u003eRanunculus Brushmark César® is a variety that looks a bit different from standard ranunculus. The flowers open in clean white, with soft pink to purple colour along the edges of the petals. This gives each bloom a hand-painted look and adds more detail than a single-colour flower.\u003c\/p\u003e\n\u003cp\u003eThe centre of the flower stays bright and fresh, while the coloured edges give depth without being too bold. The flower shape is also slightly more open, which adds to its character.\u003c\/p\u003e\n\u003cp\u003eIt is a strong variety for both the garden and cutting. The stems are long and sturdy, the flowers are large, and they last well in a vase.\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eWhy gardeners choose it\u003c\/strong\u003e\u003c\/p\u003e\n\u003cp\u003eWhite petals with soft pink to purple edges\u003c\/p\u003e\n\u003cp\u003eHand-painted look with good depth and detail\u003c\/p\u003e\n\u003cp\u003eSlightly more open flower shape\u003c\/p\u003e\n\u003cp\u003eStrong stems with good length\u003c\/p\u003e\n\u003cp\u003eLarge blooms with good impact\u003c\/p\u003e\n\u003cp\u003eLong vase life, ideal for bouquets\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eGrowing Advice\u003c\/strong\u003e\u003c\/p\u003e\n\u003cp\u003ePlant corms in autumn in mild areas, or in spring after frost\u003c\/p\u003e\n\u003cp\u003ePosition in full sun\u003c\/p\u003e\n\u003cp\u003eUse well-drained soil\u003c\/p\u003e\n\u003cp\u003eBest grown in cool conditions\u003c\/p\u003e\n\u003cp\u003eNot winter hardy in freezing weather\u003c\/p\u003e\n\u003cp\u003eRanunculus Brushmark César® works well with soft colours like blush pink, lavender and apricot, but also pairs nicely with deeper shades. It’s a good choice if you want something a little different that still fits easily into the garden or a cutting patch.\u003c\/p\u003e","published_at":"2026-04-30T12:40:41+02:00","created_at":"2026-04-17T22:09:04+02:00","updated_at":"2026-05-12T22:45:41+02:00","vendor":"DutchGrown - EU","product_type":"Ranunculus","tags":["bulb type:Ranunculus","Category:Attracts Bees \u0026 Butterflies","Category:Cut Flower Use","Category:Ideal for pots","Category:Indoor Growing","colour:pink","colour:white","Fall Planted Bulbs","fall_planted","Ranunculus","season:Early Summer"],"variants":[{"id":55534397587832,"title":"3","option1":"3","option2":null,"option3":null,"sku":"760","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"4.25","grams":0,"compare_at_price":null,"position":1,"product_id":15021592478072,"created_at":"2026-04-17T22:09:04+02:00","updated_at":"2026-05-12T22:45:41+02:00"},{"id":55534397620600,"title":"6","option1":"6","option2":null,"option3":null,"sku":"760","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"3.90","grams":0,"compare_at_price":null,"position":2,"product_id":15021592478072,"created_at":"2026-04-17T22:09:04+02:00","updated_at":"2026-05-12T22:45:41+02:00"},{"id":55