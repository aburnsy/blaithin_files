/p\u003e\n\u003cp\u003eEach corm produces several stems\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eAbout the Romance series\u003c\/strong\u003e\u003c\/p\u003e\n\u003cp\u003eNot grown from seed, but selected and grown as clones\u003c\/p\u003e\n\u003cp\u003eBred for larger, more even flowers\u003c\/p\u003e\n\u003cp\u003eStronger stems and more reliable results\u003c\/p\u003e\n\u003cp\u003eRanunculus ‘Maritime’ is a good choice if you want soft colours that change over time and add variety to your planting.\u003c\/p\u003e","published_at":"2026-04-30T12:40:36+02:00","created_at":"2026-04-17T22:08:26+02:00","updated_at":"2026-05-12T22:45:41+02:00","vendor":"DutchGrown - EU","product_type":"Ranunculus","tags":["bulb type:Ranunculus","Category:Attracts Bees \u0026 Butterflies","Category:Cut Flower Use","Category:Ideal for pots","Category:Indoor Growing","colour:cream","colour:peach","colour:pink","Fall Planted Bulbs","fall_planted","Ranunculus","Ranunculus_Romance","season:Early Summer"],"variants":[{"id":55534396539256,"title":"3","option1":"3","option2":null,"option3":null,"sku":"753","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"4.25","grams":0,"compare_at_price":null,"position":1,"product_id":15021592215928,"created_at":"2026-04-17T22:08:26+02:00","updated_at":"2026-05-12T22:45:41+02:00"},{"id":55534396572024,"title":"6","option1":"6","option2":null,"option3":null,"sku":"753","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"3.90","grams":0,"compare_at_price":null,"position":2,"product_id":15021592215928,"created_at":"2026-04-17T22:08:26+02:00","updated_at":"2026-05-12T22:45:41+02:00"},{"id":55534396604792,"title":"12","option1":"12","option2":null,"option3":null,"sku":"753","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"3.75","grams":0,"compare_at_price":null,"position":3,"product_id":15021592215928,"created_at":"2026-04-17T22:08:26+02:00","u