 long vase life\u003c\/p\u003e\n\u003cp\u003eEach corm produces several stems\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eAbout the Romance series\u003c\/strong\u003e\u003c\/p\u003e\n\u003cp\u003eNot grown from seed, but selected and grown as clones\u003c\/p\u003e\n\u003cp\u003eBred for larger, more even flowers\u003c\/p\u003e\n\u003cp\u003eStronger stems and more reliable results\u003c\/p\u003e\n\u003cp\u003eRanunculus ‘Orleans’ works well with whites, blush tones and soft pastels. It’s a good choice if you want something simple but a little different.\u003c\/p\u003e","published_at":"2026-04-30T12:40:38+02:00","created_at":"2026-04-17T22:08:46+02:00","updated_at":"2026-05-12T22:45:41+02:00","vendor":"DutchGrown - EU","product_type":"Ranunculus","tags":["bulb type:Ranunculus","Category:Attracts Bees \u0026 Butterflies","Category:Cut Flower Use","Category:Ideal for pots","Category:Indoor Growing","colour:cream","colour:pink","Fall Planted Bulbs","fall_planted","Ranunculus","Ranunculus_Romance","season:Early Summer"],"variants":[{"id":55534397063544,"title":"3","option1":"3","option2":null,"option3":null,"sku":"756","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"4.25","grams":0,"compare_at_price":null,"position":1,"product_id":15021592347000,"created_at":"2026-04-17T22:08:46+02:00","updated_at":"2026-05-12T22:45:41+02:00"},{"id":55534397096312,"title":"6","option1":"6","option2":null,"option3":null,"sku":"756","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"3.90","grams":0,"compare_at_price":null,"position":2,"product_id":15021592347000,"created_at":"2026-04-17T22:08:46+02:00","updated_at":"2026-05-12T22:45:41+02:00"},{"id":55534397129080,"title":"12","option1":"12","option2":null,"option3":null,"sku":"756","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"3.75","grams":0,"compare_at_price":null,"position":3,"product_id":15021592347000,"created_at"