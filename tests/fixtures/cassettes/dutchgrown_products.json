.com\/s\/files\/1\/0557\/2873\/4375\/files\/Ranunculus_Poodle_Ramlia-3.jpg?v=1776456559","width":990,"height":1320},{"id":75715457974648,"created_at":"2026-04-17T22:09:17+02:00","position":2,"updated_at":"2026-04-17T22:09:19+02:00","product_id":15021592445304,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0557\/2873\/4375\/files\/Ranunculus_Poodle_Ramlia-2.jpg?v=1776456559","width":990,"height":1320},{"id":75715458007416,"created_at":"2026-04-17T22:09:17+02:00","position":3,"updated_at":"2026-04-17T22:09:19+02:00","product_id":15021592445304,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0557\/2873\/4375\/files\/Ranunculus_Poodle_Ramlia-1.jpg?v=1776456559","width":990,"height":1320},{"id":75715458040184,"created_at":"2026-04-17T22:09:17+02:00","position":4,"updated_at":"2026-04-17T22:09:19+02:00","product_id":15021592445304,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0557\/2873\/4375\/files\/Ranunculus_Poodle_Ramlia-4.jpg?v=1776456559","width":990,"height":1320},{"id":75715458072952,"created_at":"2026-04-17T22:09:17+02:00","position":5,"updated_at":"2026-04-17T22:09:19+02:00","product_id":15021592445304,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0557\/2873\/4375\/files\/Ranunculus_Poodle_Ramlia-5.jpg?v=1776456559","width":990,"height":1320}],"options":[{"name":"Order size","position":1,"values":["3","6","12","15"]}]},{"id":15021592412536,"title":"Ranunculus Romance™ Seine","handle":"ranunculus-romance-seine","body_html":"\u003cp\u003eRanunculus Romance™ ‘Seine’ is a classic pink variety with a bit more depth. The buds start as a bright pink, then soften into a lighter shade as the flowers open. Some blooms stay stronger in colour while others fade, so you get a natural mix of pink tones on one plant.\u003c\/p\u003e\n\u003cp\u003eThe blooms are large and full, with many layers of petals in the classic ranunculus shape. ‘Seine’ is part of the Romance series, bred for strong stems and reliable performance.\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eWhy gardeners choose it\u003c\/strong\u003e\u003cbr\u003eLarge, full flowers with a rose-like shape\u003cbr\u003eSoft pink colour with natural variation\u003cbr\u003eBuds open bright and fade to lighter shades\u003cbr\u003eAdds gentle movement and interest to planting\u003cbr\u003eStrong stems that stay upright\u003cbr\u003eVery good as a cut flower with a long vase life\u003cbr\u003eEach corm produces several stems\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eAbout the Romance series\u003c\/strong\u003e\u003cbr\u003eNot grown from seed, but selected and grown as clones\u003cbr\u003eBred for larger, more even flowers\u003cbr\u003eStronger stems and more reliable results\u003c\/p\u003e\n\u003cp\u003eRanunculus ‘Seine’ works well with whites, blush tones and deeper pinks. It’s a good choice if you want a classic pink with a bit more variation.\u003c\/p\u003e","published_at":"2026-04-30T12:40:39+02:00","created_at":"2026-04-17T22:09:04+02:00","updated_at":"2026-05-12T22:45:41+02:00","vendor":"DutchGrown - EU","product_type":"Ranunculus","tags":["bulb type:Ranunculus","Category:Attracts Bees \u0026 Butterflies","Category:Cut Flower Use","Category:Ideal for pots","Category:Indoor Growing","colour:pink","Fall Planted Bulbs","fall_planted","Ranunculus","Ranunculus_Romance","season:Early Summer"],"variants":[{"id":55534397325688,"title":"3","option1":"3","option2":null,"option3":null,"sku":"758","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"4.25","grams":0,"compare_at_price":null,"position":1,"product_id":15021592412536,"created_at":"2026-04-17T22:09:04+02:00","updated_at":"2026-05-12T22:45:41+02:00"},{"id":55534397358456,"title":"6","option1":"6","option2":null,"option3":null,"sku":"758","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"3.90","grams":0,"compare_at_price":null,"position":2,"product_id":15021592412536,"created_at":"2026