{"products":[{"id":15855842394437,"title":"Happy Smiles","handle":"happy-smiles","body_html":"\u003cp\u003eThis beautiful daffodil truly radiates cheerfulness and lives up to its name!\u003c\/p\u003e\n\u003cp\u003e\u003cbr\u003eHappy Smiles, a large-crowned daffodil with a petal shaped like a double triangle. The daffodil has a bright orange edge that fades into cream, with a green centre.\u003c\/p\u003e","published_at":"2026-05-06T08:02:26+02:00","created_at":"2026-05-06T07:51:45+02:00","updated_at":"2026-05-12T22:45:42+02:00","vendor":"10","product_type":"Narcissus","tags":["__label:nieuw","Spring"],"variants":[{"id":57865256665413,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"N. Happy Smiles","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"8.00","grams":0,"compare_at_price":null,"position":1,"product_id":15855842394437,"created_at":"2026-05-06T07:51:45+02:00","updated_at":"2026-05-12T22:45:42+02:00"}],"images":[{"id":85490217156933,"created_at":"2026-05-06T07:54:39+02:00","position":1,"updated_at":"2026-05-06T09:18:24+02:00","product_id":15855842394437,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0567\/5165\/2954\/files\/happy-smiles-narcissus-fluwel-6074343.jpg?v=1778051904","width":1785,"height":1785},{"id":85490217091397,"created_at":"2026-05-06T07:54:39+02:00","position":2,"updated_at":"2026-05-06T09:18:26+02:00","product_id":15855842394437,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0567\/5165\/2954\/files\/happy-smiles-narcissus-fluwel-7102726.jpg?v=1778051906","width":3391,"height":3391},{"id":85490217124165,"created_at":"2026-05-06T07:54:39+02:00","position":3,"updated_at":"2026-05-06T09:18:26+02:00","product_id":15855842394437,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0567\/5165\/2954\/files\/happy-smiles-narcissus-fluwel-2772140.jpg?v=1778051906","width":2801,"height":2801},{"id":85490217189701,"created_at":"2026-